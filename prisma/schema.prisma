generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("SUPABASE_DB_URL")
}

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  businessName   String
  plan           String     @default("starter")
  onboarded      Boolean    @default(false)
  createdAt      DateTime   @default(now())
  merchants      Merchant[]
}

model Merchant {
  id                    String            @id @default(uuid())
  userId                String
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName          String
  websiteUrl            String?
  processor             String?
  processorKey          String?           @db.Text
  processorMetadata     Json?
  mid                   String?
  plan                  String            @default("starter")
  onboardMethod         String?
  status                String            @default("active")
  processingStatus      String            @default("awaiting_intake")
  merchantCategory      String?
  productsDescription   String?
  monthlyProcessing     Float             @default(0)
  averageTicket         Float             @default(0)
  highestTicket         Float             @default(0)
  countriesServed       String[]
  approvalHistory       String?
  chargebackHistory     String?
  reserveHistory        String?
  processingModel       String?
  fulfillmentTimeline   String?
  reserveAmount         Float             @default(0)
  midHealthScore        Int               @default(58)
  createdAt             DateTime          @default(now())
  transactions          Transaction[]
  alerts                Alert[]
  reports               Report[]
  uploads               StatementUpload[]
  transactionMetrics    TransactionMetrics[]
  disputeMetrics        DisputeMetrics[]
  authorizationMetrics  AuthorizationMetrics[]
  riskScores            RiskScore[]
}

model Transaction {
  id           String    @id @default(uuid())
  merchantId   String
  merchant     Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  txId         String
  amount       Float
  currency     String    @default("USD")
  country      String?
  cardBin      String?
  processor    String?
  status       String    @default("approved")
  riskScore    Int       @default(0)
  riskSignals  Json?
  disputed     Boolean   @default(false)
  refunded     Boolean   @default(false)
  ipAddress    String?
  email        String?
  createdAt    DateTime  @default(now())
}

model Alert {
  id          String    @id @default(uuid())
  merchantId  String
  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  type        String
  message     String
  read        Boolean   @default(false)
  resolved    Boolean   @default(false)
  metadata    Json?
  createdAt   DateTime  @default(now())
}

model Report {
  id          String    @id @default(uuid())
  merchantId  String
  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  week        String
  summary     Json
  fileUrl     String?
  createdAt   DateTime  @default(now())
}

model StatementUpload {
  id          String    @id @default(uuid())
  merchantId  String
  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  fileName    String
  fileType    String
  fileUrl     String
  parsed      Boolean   @default(false)
  parsedAt    DateTime?
  createdAt   DateTime  @default(now())
}

model TransactionMetrics {
  id                 String   @id @default(uuid())
  merchantId         String
  merchant           Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  date               DateTime
  volume             Float    @default(0)
  transactionCount   Int      @default(0)
  crossBorderRatio   Float    @default(0)
  ticketVariance     Float    @default(0)
  refundRatio        Float    @default(0)
  createdAt          DateTime @default(now())
}

model DisputeMetrics {
  id             String   @id @default(uuid())
  merchantId     String
  merchant       Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  date           DateTime
  disputeRatio   Float    @default(0)
  disputeCount   Int      @default(0)
  createdAt      DateTime @default(now())
}

model AuthorizationMetrics {
  id             String   @id @default(uuid())
  merchantId     String
  merchant       Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  date           DateTime
  approvalRate   Float    @default(0)
  declineRate    Float    @default(0)
  baseline       Float    @default(0)
  createdAt      DateTime @default(now())
}

model RiskScore {
  id         String   @id @default(uuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  score      Int      @default(0)
  status     String   @default("stable")
  disputeRatioInput   Float @default(0)
  authDeviationInput  Float @default(0)
  volumeSpikeInput    Float @default(0)
  refundRatioInput    Float @default(0)
  crossBorderInput    Float @default(0)
  createdAt  DateTime @default(now())
}
